PORT=8080
ALLOWED_ORIGIN=https://badukplatform.vercel.app

# URL of your deployed KataGo server.
# Examples:
# KATAGO_SERVER_URL=http://127.0.0.1:2718
# KATAGO_SERVER_URL=https://your-katago-server.onrender.com
KATAGO_SERVER_URL=

# Adjust this if your katago-server exposes a different analyze path.
KATAGO_ANALYZE_PATH=/api/v1/analyze
